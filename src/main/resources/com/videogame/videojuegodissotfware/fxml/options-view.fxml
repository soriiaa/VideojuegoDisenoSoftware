<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" styleClass="background" prefHeight="720" prefWidth="1280"
           xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.videogame.videojuegodissotfware.OptionsController">

    <stylesheets>
        <URL value="@../css/options.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="30.0" maxWidth="420">
        <Label fx:id="gameTime" text="Tiempo de la partida: 23:01" styleClass="timeText"/>
        <Button fx:id="resumeBtn" styleClass="menuBtn" text="CONTINUAR PARTIDA" maxWidth="Infinity"/>
        <Button fx:id="restartBtn" styleClass="menuBtn" text="REINICIAR PARTIDA" maxWidth="Infinity"/>
        <Button fx:id="exitBtn" styleClass="menuBtn" text="SALIR DE LA PARTIDA" maxWidth="Infinity"/>
    </VBox>


</StackPane>
