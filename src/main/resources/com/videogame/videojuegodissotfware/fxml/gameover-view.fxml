<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.net.URL?>
<VBox alignment="CENTER" spacing="20"
      style="-fx-background-color: rgba(0, 0, 0, 0.8);"
      xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@../css/gameover.css" />
    </stylesheets>

    <Label text="GAME OVER" styleClass="textOver" />

    <Label text="Tu aventura ha llegado a su fin." styleClass="subOver" />

    <Region prefHeight="50" />
    <Label text="Cerrando aplicación..." styleClass="subOver" />
</VBox>