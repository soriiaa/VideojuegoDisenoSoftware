<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" spacing="30.0" styleClass="backgroundFight" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.videogame.videojuegodissotfware.gui.controllers.FightController">

    <stylesheets>
        <URL value="@../css/figth.css" />
    </stylesheets>

    <HBox maxHeight="450.0" minHeight="450.0" prefHeight="450.0" prefWidth="200.0" VBox.vgrow="NEVER">
        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                <VBox alignment="TOP_CENTER" minHeight="300.0" minWidth="300.0">
                    <ImageView fx:id="enemyImage" fitHeight="300.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" styleClass="imgCombate" />
                    <padding>
                        <Insets bottom="10.0" />
                    </padding>
                </VBox>
                <HBox alignment="TOP_CENTER" spacing="20.0" styleClass="zonaBtn">
                    <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS">
                        <Button fx:id="atackBtn" onAction="#handleAttack" focusTraversable="false" styleClass="itemsButton, btn-atacar" text="ATACAR" />
                        <Button fx:id="protectBtn" onAction="#handleProtect" focusTraversable="false" styleClass="itemsButton, btn-protegerse" text="PROTEGERSE" />
               <HBox.margin>
                  <Insets left="20.0" right="20.0" />
               </HBox.margin>
                    </VBox>
                    <VBox alignment="CENTER" fillWidth="false" prefHeight="100.0" prefWidth="50.0">
                          <Button fx:id="potionBtn" onAction="#handlePotion" alignment="TOP_LEFT" focusTraversable="false" styleClass="itemsButton">
                              <graphic>
                                  <ImageView fitHeight="28.0" fitWidth="28.0">
                                      <Image url="@../images/pocion.png" />
                                  </ImageView>
                              </graphic>
                          </Button>
                    </VBox>
                    <HBox.margin>
                        <Insets bottom="10.0" top="10.0" />
                    </HBox.margin>

                </HBox>
                <HBox.margin>
                    <Insets left="10.0" right="10.0" top="20.0" />
                </HBox.margin>
            </VBox>

            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                  <Label fx:id="enemyName" alignment="CENTER" styleClass="nameEnemy" text="NOMBRE ENEMIGO">
            <VBox.margin>
               <Insets bottom="10.0" />
            </VBox.margin></Label>
                <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="zonaEnemy">
                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label styleClass="atrEnemy" text="HP:" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="enemyHp" styleClass="atrEnemy" text="50" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label styleClass="atrEnemy" text="Resistencia:" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="enemyRes" styleClass="atrEnemy" text="30" />
                        </HBox>
                       <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="37.0" spacing="10">
                           <Label styleClass="atrEnemy" text="Ataque:" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="enemyDamage" styleClass="atrEnemy" text="50" />
                       </HBox>
                       <HBox.margin>
                          <Insets />
                       </HBox.margin>
                       <padding>
                          <Insets right="10.0" />
                       </padding>

                    </VBox>
            <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" spacing="10.0">
                  <HBox alignment="CENTER_LEFT" spacing="10">

                        <Label styleClass="atrEnemy" text="Estado:" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="enemyState" styleClass="atrEnemy" text="Dañado" />
                  </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">

                    <Label styleClass="atrEnemy" text="Estrategia:" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="enemyStrategy" styleClass="atrEnemy" text="Dañado" />
                </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="atrEnemy" text="Botin:" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="enemyReward" styleClass="atrEnemy" text="100" />
                  </HBox>
               <padding>
                  <Insets left="10.0" />
               </padding>
            </VBox>
                  <HBox.margin>
                      <Insets bottom="10.0" top="10.0" />
                  </HBox.margin>
            <VBox.margin>
               <Insets left="5.0" right="10.0" />
            </VBox.margin>
                </HBox>


                <VBox alignment="CENTER">
                    <ImageView fitHeight="350.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true" styleClass="imgCombate">
                        <Image url="@../images/guerreroFight.png" />
               <VBox.margin>
                  <Insets />
               </VBox.margin>
                    </ImageView>
                    <padding>
                        <Insets top="20.0" />
                    </padding>
            <VBox.margin>
               <Insets />
            </VBox.margin>
                </VBox>
                <HBox.margin>
                     <Insets left="10.0" right="10.0" top="20.0" />
                </HBox.margin>
            </VBox>
      </HBox>

    <!-- Zona de mensajes -->
    <ScrollPane fx:id="scrollLog" fitToHeight="true" fitToWidth="true" styleClass="combat-log" VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="vboxMensajes" spacing="5.0" styleClass="log-container">
                <padding>
                    <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>
