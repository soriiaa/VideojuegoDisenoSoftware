<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<StackPane alignment="CENTER" styleClass="background" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.videogame.videojuegodissotfware.LaunchController">

  <stylesheets>
      <URL value="@../css/launch.css" />
  </stylesheets>

  <VBox styleClass="launchBox">
    <Label styleClass="title" text="NOMBRE VIDEOGAME" />
    <HBox>
      <Separator minWidth="60.0" opacity="0.0" prefWidth="60" />
      <TextField fx:id="name" promptText="Nombre del guerrero" styleClass="input" />
      <Separator minWidth="60.0" opacity="0.0" prefWidth="60" />
    </HBox>
    <ImageView fitWidth="200" fitHeight="100">
      <Image url="@../images/Empezar.png"/>
    </ImageView>
  </VBox>
</StackPane>
